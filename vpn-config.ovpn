# Additional HTTP/SSL Tweaks for WyrVPN
http-proxy 104.21.45.180 8080
http-proxy-retry
http-proxy-timeout 5

# Network Settings
sndbuf 524288
rcvbuf 524288
push "sndbuf 524288"
push "rcvbuf 524288"

# Keep Alive
keepalive 20 60
ping-timer-rem
persist-remote-ip
persist-key

# DNS Configuration
dhcp-option DNS 8.8.8.8
dhcp-option DNS 8.8.4.4
dhcp-option DNS 1.1.1.1

# Log Files
log /sdcard/Android/data/com.wireguard.android/files/vpn.log
status /sdcard/Android/data/com.wireguard.android/files/status.log
