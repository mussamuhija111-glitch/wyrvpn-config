# WyrVPN HTTP/SSL Configuration
# Compatible with HTTP/SSL Protocol

client
proto tcp
remote 104.21.45.180 443
cipher AES-256-CBC
auth SHA256
resolv-retry infinite
nobind
persist-key
persist-tun
remote-random
comp-lz4
verb 3
mute 20
route-delay 2
route-up "/etc/openvpn/up.sh"
route-pre-down "/etc/openvpn/down.sh"

# TLS Configuration
tls-client
tls-version-min 1.2
tls-cipher DEFAULT:!MD5

